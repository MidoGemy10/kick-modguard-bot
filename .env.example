# Discord
DISCORD_TOKEN=PUT_DISCORD_BOT_TOKEN_HERE
DISCORD_CLIENT_ID=PUT_DISCORD_APPLICATION_CLIENT_ID_HERE
GUILD_ID=PUT_YOUR_SERVER_ID_HERE
LOG_CHANNEL_ID=PUT_MOD_LOG_CHANNEL_ID_HERE
ADMIN_ROLE_ID=OPTIONAL_ADMIN_ROLE_ID

# قناة لوحة وجود المودات
PRESENCE_CHANNEL_ID=PUT_PRESENCE_PANEL_CHANNEL_ID_HERE

# Server / Webhook
PORT=3000
PUBLIC_URL=https://your-domain.com
DATABASE_PATH=/app/data/modguard.sqlite

# Kick
KICK_BROADCASTER_USER_ID=PUT_KICK_CHANNEL_USER_ID_HERE
KICK_APP_ACCESS_TOKEN=PUT_KICK_APP_OR_USER_ACCESS_TOKEN_HERE
KICK_VERIFY_SIGNATURE=true

# Presence panel rules
PRESENCE_ACTIVE_MINUTES=30
PRESENCE_UPDATE_SECONDS=10
MIN_MESSAGE_LENGTH=3
DUPLICATE_WINDOW_MINUTES=10
COUNT_ONLY_WHEN_LIVE=true
CLOSE_SHIFT_WHEN_STREAM_ENDS=true
